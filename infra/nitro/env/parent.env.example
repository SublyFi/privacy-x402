RUST_LOG=info

A402_PARENT_INGRESS_LISTEN=0.0.0.0:443
A402_PARENT_INTERCONNECT_MODE=vsock
A402_ENCLAVE_CID=16
A402_ENCLAVE_INGRESS_PORT=5000
A402_ENCLAVE_EGRESS_PORT=5001
A402_ENCLAVE_KMS_PORT=5002
A402_ENCLAVE_SNAPSHOT_PORT=5003

A402_SNAPSHOT_DIR=/var/lib/a402/snapshots
A402_KMS_REGION=us-east-1

# Optional: restrict relay egress targets.
# Examples:
#   A402_EGRESS_ALLOWLIST=api.devnet.solana.com:443,*.amazonaws.com:443,127.0.0.1:3200
#   A402_EGRESS_ALLOWLIST=*.g.alchemy.com:443,*.amazonaws.com:443
# Leave unset to disable application-level egress filtering.
# A402_EGRESS_ALLOWLIST=
