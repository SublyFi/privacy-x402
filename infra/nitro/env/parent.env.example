RUST_LOG=info

SUBLY402_PARENT_INGRESS_LISTEN=0.0.0.0:443
SUBLY402_PARENT_INTERCONNECT_MODE=vsock
SUBLY402_ENCLAVE_CID=16
SUBLY402_ENCLAVE_INGRESS_PORT=5000
SUBLY402_ENCLAVE_EGRESS_PORT=5001
SUBLY402_ENCLAVE_KMS_PORT=5002
SUBLY402_ENCLAVE_SNAPSHOT_PORT=5003

SUBLY402_SNAPSHOT_DIR=/var/lib/subly402/snapshots
SUBLY402_KMS_REGION=us-east-1

# Optional: restrict relay egress targets.
# Examples:
#   SUBLY402_EGRESS_ALLOWLIST=api.devnet.solana.com:443,*.amazonaws.com:443,127.0.0.1:3200
#   SUBLY402_EGRESS_ALLOWLIST=*.g.alchemy.com:443,*.amazonaws.com:443
# Leave unset to disable application-level egress filtering.
# SUBLY402_EGRESS_ALLOWLIST=
