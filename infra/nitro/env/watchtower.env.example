RUST_LOG=info

SUBLY402_WATCHTOWER_LISTEN=127.0.0.1:3200
SUBLY402_WATCHTOWER_STORE_PATH=/var/lib/subly402/watchtower/receipts.json
SUBLY402_WATCHTOWER_POLL_SEC=10

SUBLY402_PROGRAM_ID=<devnet_program_id>
SUBLY402_VAULT_CONFIG=<vault_config_pubkey>
SUBLY402_SOLANA_RPC_URL=<devnet_rpc_url>
SUBLY402_WATCHTOWER_KEYPAIR_B64=<funded_watchtower_keypair_base64>
