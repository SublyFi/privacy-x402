RUST_LOG=info

A402_WATCHTOWER_LISTEN=127.0.0.1:3200
A402_WATCHTOWER_STORE_PATH=/var/lib/a402/watchtower/receipts.json
A402_WATCHTOWER_POLL_SEC=10

A402_PROGRAM_ID=<devnet_program_id>
A402_VAULT_CONFIG=<vault_config_pubkey>
A402_SOLANA_RPC_URL=<devnet_rpc_url>
A402_WATCHTOWER_KEYPAIR_B64=<funded_watchtower_keypair_base64>
