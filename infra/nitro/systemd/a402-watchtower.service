[Unit]
Description=A402 receipt watchtower
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=a402
Group=a402
WorkingDirectory=/var/lib/a402
ExecStart=/opt/a402/bin/start-watchtower.sh /etc/a402/watchtower.env
Restart=always
RestartSec=5
LimitNOFILE=65536
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/a402 /var/log/a402 /etc/a402 /opt/a402

[Install]
WantedBy=multi-user.target
