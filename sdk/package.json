{
  "name": "subly402-sdk",
  "version": "0.1.1",
  "description": "Privacy-first x402 client SDK for Solana. Pay paid APIs through a TEE-based vault so on-chain observers never see the buyer-to-provider edge.",
  "license": "ISC",
  "author": "SublyFi",
  "homepage": "https://github.com/SublyFi/privacy-x402#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SublyFi/privacy-x402.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/SublyFi/privacy-x402/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./vault": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.js"
    },
    "./audit": {
      "types": "./dist/audit.d.ts",
      "import": "./dist/audit.js",
      "require": "./dist/audit.js"
    },
    "./arcium": {
      "types": "./dist/arcium.d.ts",
      "import": "./dist/arcium.js",
      "require": "./dist/arcium.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@solana/kit": "^6.8.0",
    "bs58": "^4.0.1",
    "cbor": "^10.0.12",
    "tweetnacl": "^1.0.3"
  },
  "peerDependencies": {
    "@arcium-hq/client": "0.9.7",
    "@coral-xyz/anchor": "^0.32.1",
    "@noble/curves": "^1.4.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1"
  },
  "peerDependenciesMeta": {
    "@arcium-hq/client": {
      "optional": true
    },
    "@coral-xyz/anchor": {
      "optional": true
    },
    "@noble/curves": {
      "optional": true
    },
    "@solana/spl-token": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    },
    "bn.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arcium-hq/client": "0.9.7",
    "@coral-xyz/anchor": "^0.32.1",
    "@noble/curves": "^1.4.0",
    "@solana/spl-token": "^0.4.14",
    "@types/bn.js": "^5.1.6",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3",
    "bn.js": "^5.2.1",
    "@solana/web3.js": "^1.95.0"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "keywords": [
    "x402",
    "subly402",
    "solana",
    "payment",
    "privacy",
    "ai-agent",
    "tee",
    "nitro-enclave",
    "usdc",
    "micropayment"
  ]
}
